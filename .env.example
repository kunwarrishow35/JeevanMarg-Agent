# JeevanMarg Backend Environment Variables

# Application
APP_NAME=JeevanMarg
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./jeevanmarg.db

# Authentication (CHANGE IN PRODUCTION)
JWT_SECRET=jeevanmarg-your-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Google ADK (Required for agent functionality)
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Demo
DEMO_CITY=Delhi
AUTO_PROGRESS_SCENARIOS=true
